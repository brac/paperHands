# PaperHands configuration — copy to `.env` and fill in. `.env` is git-ignored.
# All values below are OPTIONAL for this slice (scaffold + risk gate); secrets become
# required only in the slices that use them.

# Logging
PAPERHANDS_LOG_LEVEL=INFO

# Strategy mode: rules-only | llm | rebalance | yolo
#   rules-only / llm  -> legacy alpha path (archived under legacy/; no defensible edge found)
#   rebalance         -> hands-off ETF rebalancer (the current core; see PAPERHANDS_REBALANCE__*)
#   yolo              -> max-risk momentum/meme-hype sleeve (contrast line; see PAPERHANDS_YOLO__)
# rebalance + yolo both need target-weight sizing + screen bypass; --mode coerces these for you.
PAPERHANDS_STRATEGY_MODE=rules-only

# --- Historical data provider + cache ---
PAPERHANDS_DATA__PROVIDER=tiingo
PAPERHANDS_DATA__CACHE_DIR=data_cache
PAPERHANDS_DATA__TIINGO_BASE_URL=https://api.tiingo.com

# --- Ingest / snapshot ---
# Calendar-day lookback of price history attached per symbol (~415 trading days).
PAPERHANDS_INGEST__HISTORY_DAYS=600

# --- Screen knobs (user-tunable universe filter + ranking) ---
# List knobs are JSON arrays. A market-cap floor is intentionally absent (no point-in-time
# shares-outstanding from Tiingo EOD).
PAPERHANDS_SCREEN__MIN_AVG_DOLLAR_VOLUME=10000000.0
PAPERHANDS_SCREEN__MIN_PRICE=5.0
PAPERHANDS_SCREEN__SECTORS_INCLUDE=[]
PAPERHANDS_SCREEN__SECTORS_EXCLUDE=[]
PAPERHANDS_SCREEN__WATCHLIST=[]
PAPERHANDS_SCREEN__LIQUIDITY_WINDOW=20
PAPERHANDS_SCREEN__MOMENTUM_WINDOW=60
PAPERHANDS_SCREEN__MOMENTUM_WEIGHT=1.0
PAPERHANDS_SCREEN__RELEVANCE_WEIGHT=0.0
PAPERHANDS_SCREEN__MAX_CANDIDATES=20

# --- Signals (technical-indicator window knobs, in bars) ---
PAPERHANDS_SIGNALS__SMA_SHORT_WINDOW=20
PAPERHANDS_SIGNALS__SMA_LONG_WINDOW=50
PAPERHANDS_SIGNALS__RSI_WINDOW=14
PAPERHANDS_SIGNALS__ROC_WINDOW=60
PAPERHANDS_SIGNALS__ATR_WINDOW=14
PAPERHANDS_SIGNALS__ZSCORE_WINDOW=20

# --- Strategy (rules-mode proposal knobs; gate still enforces hard caps) ---
PAPERHANDS_STRATEGY__MAX_NEW_POSITIONS=5
PAPERHANDS_STRATEGY__MAX_TARGET_WEIGHT=0.15
PAPERHANDS_STRATEGY__MOMENTUM_BUY_THRESHOLD=0.0
PAPERHANDS_STRATEGY__ZSCORE_OVERSOLD=-1.5
PAPERHANDS_STRATEGY__RSI_OVERBOUGHT=70.0
PAPERHANDS_STRATEGY__SELL_THRESHOLD=0.0
PAPERHANDS_STRATEGY__NEWS_CONVICTION_BOOST=0.1
PAPERHANDS_STRATEGY__NEWS_VETO_SENTIMENT=-0.5

# --- Rebalancer (ETF target-weight basket; active when STRATEGY_MODE=rebalance) ---
# Weights are a JSON object; sum may be < 1.0 (remainder = cash) but never > 1.0.
PAPERHANDS_REBALANCE__TARGET_WEIGHTS={"SPY":0.6,"BND":0.3,"GLD":0.1}
PAPERHANDS_REBALANCE__DEFENSIVE_SYMBOL=BND
PAPERHANDS_REBALANCE__EQUITY_SYMBOLS=["SPY"]
# Trigger: drift | schedule | both
PAPERHANDS_REBALANCE__TRIGGER=drift
PAPERHANDS_REBALANCE__DRIFT_BAND=0.05
# Regime de-risk overlay (RISK control, not a predictor; default off)
PAPERHANDS_REBALANCE__REGIME_DERISK_ENABLED=false
PAPERHANDS_REBALANCE__REGIME_DERISK_SHIFT=0.5
PAPERHANDS_REBALANCE__REGIME_MA_WINDOW=200

# --- YOLO sleeve (max-risk momentum/meme-hype; active when STRATEGY_MODE=yolo) ---
# Holds the hottest TOP_N names, concentrated. Hype = blend of price/volume proxy components
# (momentum/volume/breakout) + the real WSB social score (PAPERHANDS_SOCIAL__ below). Raise
# SOCIAL_WEIGHT to let WSB meme hype drive the buys; leave 0 for the pure price/volume proxy.
PAPERHANDS_YOLO__TOP_N=5
PAPERHANDS_YOLO__MAX_POSITION_PCT=0.5
PAPERHANDS_YOLO__MOMENTUM_WEIGHT=1.0
PAPERHANDS_YOLO__VOLUME_WEIGHT=1.0
PAPERHANDS_YOLO__BREAKOUT_WEIGHT=0.5
PAPERHANDS_YOLO__SOCIAL_WEIGHT=0.0
PAPERHANDS_YOLO__CONVICTION_WEIGHTED=true
# Optional blowup guard: full-exit a held name down more than this from avg cost (unset = off).
# PAPERHANDS_YOLO__STOP_LOSS_PCT=0.3

# --- Social / exotic 'hype' feed (Reddit-WSB; the YOLO sleeve's real meme input) ---
# Off by default. Build the point-in-time aggregate once from a raw WSB archive:
#   python -m ingest.wsb --csv path/to/wallstreetbets.csv --out data_cache/wsb_daily.sqlite
# then set ENABLED=true. The feed only reads days <= the decision date (no look-ahead).
PAPERHANDS_SOCIAL__ENABLED=false
PAPERHANDS_SOCIAL__SOURCE=wsb
PAPERHANDS_SOCIAL__WSB_CSV_PATH=
PAPERHANDS_SOCIAL__AGGREGATE_PATH=data_cache/wsb_daily.sqlite
PAPERHANDS_SOCIAL__MENTION_WINDOW=7
PAPERHANDS_SOCIAL__VELOCITY_WINDOW=3
PAPERHANDS_SOCIAL__MIN_POST_SCORE=0

# --- Backtest engine ---
PAPERHANDS_ENGINE__CALENDAR_SYMBOL=SPY
PAPERHANDS_ENGINE__REBALANCE_EVERY_N_DAYS=1
PAPERHANDS_ENGINE__ADV_WINDOW=20
# Skip the screener and use the run's universe directly (set true for the rebalancer).
PAPERHANDS_ENGINE__SCREEN_BYPASS=false

# --- Record (results store) ---
PAPERHANDS_RECORD__DB_PATH=results.sqlite

# --- Simulated broker (starting capital + execution cost model) ---
PAPERHANDS_BROKER__STARTING_CASH=100000.0
PAPERHANDS_BROKER__SLIPPAGE_BPS=5.0
PAPERHANDS_BROKER__SPREAD_BPS=2.0
PAPERHANDS_BROKER__COMMISSION_PER_ORDER=0.0

# --- Risk gate knobs (the sovereign gate; all config-driven) ---
PAPERHANDS_RISK__MAX_POSITION_PCT=0.20
PAPERHANDS_RISK__MAX_POSITIONS=10
PAPERHANDS_RISK__MIN_PRICE=5.0
PAPERHANDS_RISK__MIN_AVG_DOLLAR_VOLUME=1000000.0
PAPERHANDS_RISK__DAILY_LOSS_LIMIT=0.05
# Buy-sizing: new-dollars (legacy alpha path) | target-weight (ETF rebalancer).
PAPERHANDS_RISK__SIZING=new-dollars
# Rebalance churn guards (effective |delta| floor = max(dollars, pct*equity); 0 = off).
PAPERHANDS_RISK__MIN_TRADE_DOLLARS=0.0
PAPERHANDS_RISK__MIN_TRADE_PCT=0.0
# Cap on total traded notional (buys+sells) per gate call as a fraction of equity. Leave
# unset for no cap (a full two-sided rebalance can legitimately exceed 1.0); e.g. 0.5 to cap.
# PAPERHANDS_RISK__MAX_TURNOVER_PCT=0.5

# --- Secrets (not needed for this slice) ---
# Historical data provider (Tiingo default; used by the Data Provider slice)
TIINGO_API_KEY=
# LLM strategy mode (used by strategy/ llm mode)
ANTHROPIC_API_KEY=
# Alpaca paper/live execution (used by the Phase-2 execution loop)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Live-trading guard: keep LIVE_TRADING=false; live requires LIVE_CONFIRM=I_UNDERSTAND
LIVE_TRADING=false
LIVE_CONFIRM=
